{
  "name": "gitfolio",
  "version": "1.0.0",
  "packageManager": "bun@1.4.0",
  "description": "Git contribution portfolio exporter — scan repos, pick an author, export diffs to markdown",
  "author": "AungMyoKyaw",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder --config electron-builder.config.cjs",
    "package:mac": "electron-builder --config electron-builder.config.cjs --mac --publish never",
    "package:win": "electron-builder --config electron-builder.config.cjs --win --publish never",
    "package:linux": "electron-builder --config electron-builder.config.cjs --linux --publish never",
    "release:mac": "electron-builder --config electron-builder.config.cjs --mac --publish always",
    "release:win": "electron-builder --config electron-builder.config.cjs --win --publish always",
    "release:linux": "electron-builder --config electron-builder.config.cjs --linux --publish always",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.2",
    "vite": "^5.3.1",
    "vitest": "^2.1.9"
  }
}
